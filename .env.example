# Seven Bet — Production Environment Variables
# Copy this to .env and fill in the values

# Turso/libSQL Database
TURSO_DATABASE_URL=libs://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Veriff KYC (optional - leave empty for dev)
VERIFF_API_KEY=
VERIFF_SHARED_SECRET=

# GeoComply Geolocation (optional - leave empty for dev)
GEOCOMPLY_API_KEY=
GEOCOMPLY_SECRET=
